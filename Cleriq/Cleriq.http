### Creează ședință nouă
# @name sedintaConvocare
POST {{host}}/api/Sedinte
Content-Type: application/json
Authorization: Bearer {{loginAdmin.response.body.$.token}}

{
  "titlu": "Ședință test convocare",
  "numar": "1/2026",
  "tip": 1,
  "dataOra": "2026-06-15T11:00:00Z",
  "loc": "Sala mare a Primăriei Slobozia",
  "modDesfasurare": 1
}

### Punct 1
POST {{host}}/api/Sedinte/{{sedintaConvocare.response.body.$.id}}/Puncte
Content-Type: application/json
Authorization: Bearer {{loginAdmin.response.body.$.token}}

{
  "ordine": 1,
  "titlu": "Aprobare buget local 2026",
  "descriere": "Discutarea și aprobarea bugetului pe anul 2026",
  "tip": 1,
  "necesitaVot": true,
  "tipMajoritate": 2
}

### Punct 2
POST {{host}}/api/Sedinte/{{sedintaConvocare.response.body.$.id}}/Puncte
Content-Type: application/json
Authorization: Bearer {{loginAdmin.response.body.$.token}}

{
  "ordine": 2,
  "titlu": "Informare privind investițiile în infrastructură",
  "descriere": null,
  "tip": 2,
  "necesitaVot": false,
  "tipMajoritate": null
}






  // / / / -----


  ### Convocare în masă
POST {{host}}/api/Sedinte/{{sedintaConvocare.response.body.$.id}}/Convocare
Authorization: Bearer {{loginAdmin.response.body.$.token}}





---------
### Verifică detalii convocări
GET {{host}}/api/Sedinte/{{sedintaConvocare.response.body.$.id}}/Convocari
Authorization: Bearer {{loginAdmin.response.body.$.token}}

###  Verifică starea ședinței
GET {{host}}/api/Sedinte
Authorization: Bearer {{loginAdmin.response.body.$.token}}


### Re-convocare (idempotență)
POST {{host}}/api/Sedinte/{{sedintaConvocare.response.body.$.id}}/Convocare
Authorization: Bearer {{loginAdmin.response.body.$.token}}

