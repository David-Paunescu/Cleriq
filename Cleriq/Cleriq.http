Content-Type: application/json
Authorization: Bearer {{loginSecretar.response.body.$.token}}

{
  "ordine": 2,
  "titlu": "Informare execuție buget Q3",
  "descriere": null,
  "tip": 2,
  "necesitaVot": false,
  "tipMajoritate": null
}

