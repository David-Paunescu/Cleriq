### Puncte 1. Creează ședință pentru testarea punctelor
# @name sedintaPuncte
POST {{host}}/api/Sedinte
Content-Type: application/json
Authorization: Bearer {{loginAdmin.response.body.$.token}}

{
  "titlu": "Ședință test puncte",
  "numar": "PCT-1",
  "tip": 1,
  "dataOra": "2026-10-01T14:00:00Z",
  "loc": "Sala mare",
  "modDesfasurare": 1
}

### Puncte 2. Secretar adaugă punct cu vot (HCL, majoritate simplă)
POST {{host}}/api/Sedinte/{{sedintaPuncte.response.body.$.id}}/Puncte
Content-Type: application/json
Authorization: Bearer {{loginSecretar.response.body.$.token}}

{
  "ordine": 1,
  "titlu": "Aprobarea bugetului local pe 2026",
  "descriere": "Proiect HCL nr. 12",
  "tip": 1,
  "necesitaVot": true,
  "tipMajoritate": 1
}

